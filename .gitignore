# 비밀값/자격증명 — 절대 커밋 금지 (SealedSecret 만 커밋)
*.plain.yaml
*-plain.yaml
secrets/plain/
/tmp-secrets/
*.kubeconfig
kubeconfig*
.env
.env.*
!.env.example
# 시크릿 SSOT 평문 — .example 만 커밋
deploy/secrets/secrets.env
deploy/secrets/*.env
!deploy/secrets/secrets.env.example

# airgap 번들 산출물 (대용량 — 커밋 금지, 전송용 로컬 산출)
dist/

# dbt
dbt/**/target/
dbt/**/dbt_packages/
dbt/**/logs/

# 파이썬/도구 산출물
__pycache__/
*.pyc
.venv/

# dbt 로컬 사용자 식별자(추적)
dbt/**/.user.yml

# 영속 PV 폴더(레포 내부 기본값) — DB 데이터·비밀, 절대 커밋 금지
.maxdl-pv/
