# =============================================================================
# maxdl 시크릿 SSOT 템플릿 — 이 .example 만 커밋한다.
# -----------------------------------------------------------------------------
# 사용법:
#   1) cp deploy/secrets/secrets.env.example deploy/secrets/secrets.env
#   2) secrets.env 의 각 값을 실제 운영 자격으로 채운다(평문, 미커밋·gitignore).
#   3) scripts/seal-from-env.sh 실행 → 대상 클러스터 키로 재봉인/적용.
# 값에 작은따옴표가 들어가면 큰따옴표로 감싸거나 이스케이프.
# =============================================================================

# --- 소스 DB: maxplatform (PostgreSQL) ---
SRC_MAXPLATFORM_HOST='CHANGE_ME'
SRC_MAXPLATFORM_PORT='5432'
SRC_MAXPLATFORM_DATABASE='maxplatform'
SRC_MAXPLATFORM_USERNAME='CHANGE_ME'
SRC_MAXPLATFORM_PASSWORD='CHANGE_ME'
SRC_MAXPLATFORM_TYPE='postgres'

# --- 소스 DB: maxapex (PostgreSQL) ---
SRC_MAXAPEX_HOST='CHANGE_ME'
SRC_MAXAPEX_PORT='5432'
SRC_MAXAPEX_DATABASE='maxapex'
SRC_MAXAPEX_USERNAME='CHANGE_ME'
SRC_MAXAPEX_PASSWORD='CHANGE_ME'
SRC_MAXAPEX_TYPE='postgres'

# --- 소스 DB: pfms (MSSQL) ---
SRC_PFMS_HOST='CHANGE_ME'
SRC_PFMS_PORT='1433'
SRC_PFMS_DATABASE='pfms'
SRC_PFMS_USERNAME='CHANGE_ME'
SRC_PFMS_PASSWORD='CHANGE_ME'
SRC_PFMS_TYPE='mssql'

# --- 소스 DB: maxtdoracle (Oracle) ---
SRC_MAXTDORACLE_HOST='CHANGE_ME'
SRC_MAXTDORACLE_PORT='1521'
SRC_MAXTDORACLE_DATABASE='MAXTDORACLE'
SRC_MAXTDORACLE_USERNAME='CHANGE_ME'
SRC_MAXTDORACLE_PASSWORD='CHANGE_ME'
SRC_MAXTDORACLE_TYPE='oracle'
SRC_MAXTDORACLE_SERVICENAME='xe'

# --- SeaweedFS S3 (3개 네임스페이스 공통) ---
# 주의: maxplatform 운영과 공유 스토리지면 datastore identity 키 그대로 사용.
S3_ACCESS_KEY='CHANGE_ME'
S3_SECRET_KEY='CHANGE_ME'
S3_ENDPOINT='http://host.k3d.internal:8333'
S3_REGION='kr-dw-pt-001'
S3_WAREHOUSE_BUCKET='maxdl-warehouse'

# --- Polaris ---
POLARIS_BOOTSTRAP_CLIENT_ID='root'
POLARIS_BOOTSTRAP_CLIENT_SECRET='CHANGE_ME'
POLARIS_BOOTSTRAP_REALM='POLARIS'
# Trino 용 서비스 principal (clientId:clientSecret 형식 한 줄)
POLARIS_OAUTH_CREDENTIAL='CHANGE_ME:CHANGE_ME'
POLARIS_PERSISTENCE_JDBC_URL='jdbc:postgresql://polaris-postgresql.maxdl-catalog.svc.cluster.local:5432/polaris'
POLARIS_PERSISTENCE_USERNAME='polaris'
POLARIS_PERSISTENCE_PASSWORD='CHANGE_ME'

# --- Airbyte / Airflow / Superset / OpenMetadata ---
AIRBYTE_CLIENT_ID='CHANGE_ME'
AIRBYTE_CLIENT_SECRET='CHANGE_ME'
AIRFLOW_WEBSERVER_SECRET_KEY='CHANGE_ME'
OM_AIRFLOW_PASSWORD='CHANGE_ME'
OM_MYSQL_PASSWORD='CHANGE_ME'
SUPERSET_ADMIN_PASSWORD='CHANGE_ME'
SUPERSET_SECRET_KEY='CHANGE_ME'

# --- Trino 인증 (maxplatform SSO=JWT, 환경변수화) ---
# 사람=JWT(SSO), 기계(dbt/Airflow)=PASSWORD(svc-dbt). 머신토큰 미발급이라
# dbt 는 password-file 경로. JWKS 는 공개키(비밀 아님)지만 환경별 주소 상이.
MAXDL_SSO_JWKS_URL='https://CHANGE_ME/.well-known/jwks.json'
MAXDL_SSO_ISSUER='CHANGE_ME'
MAXDL_SSO_AUDIENCE='CHANGE_ME'
MAXDL_SSO_PRINCIPAL_FIELD='sub'
# dbt/Airflow 전용 서비스계정 평문(컷오버 시 htpasswd Secret 으로 생성)
SVC_DBT_PASSWORD='CHANGE_ME'
